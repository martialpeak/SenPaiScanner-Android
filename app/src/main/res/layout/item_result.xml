<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="8dp"
    android:paddingVertical="10dp"
    android:background="@drawable/result_item_bg">

    <!-- Health dot -->
    <View
        android:id="@+id/dot_health"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:background="@drawable/dot_shape"
        android:layout_marginEnd="8dp"/>

    <!-- IP:Port -->
    <TextView
        android:id="@+id/tv_ip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="3"
        android:textColor="@color/text_primary"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:singleLine="true"/>

    <!-- Latency -->
    <TextView
        android:id="@+id/tv_latency"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:textStyle="bold"/>

    <!-- Loss -->
    <TextView
        android:id="@+id/tv_loss"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:fontFamily="monospace"/>

    <!-- Colo -->
    <TextView
        android:id="@+id/tv_colo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/accent"
        android:textSize="11sp"
        android:fontFamily="monospace"/>

    <!-- TLS / Status (hidden in small space, shown as badge) -->
    <TextView
        android:id="@+id/tv_tls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_dim"
        android:textSize="9sp"
        android:fontFamily="monospace"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_dim"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:layout_marginStart="4dp"
        android:visibility="gone"/>

</LinearLayout>
