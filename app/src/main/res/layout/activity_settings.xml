<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_probe_sni"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

        <EditText
            android:id="@+id/et_probe_sni"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:inputType="textNoSuggestions"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_probe_path"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

        <EditText
            android:id="@+id/et_probe_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:inputType="textNoSuggestions"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_max_results"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

        <EditText
            android:id="@+id/et_max_results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:inputType="number"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_stop_after"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

        <EditText
            android:id="@+id/et_stop_after"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:inputType="number"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_skip_failed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_skip_failed"
            android:textColor="@color/text_secondary"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_vibrate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_vibrate"
            android:textColor="@color/text_secondary"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_foreground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_foreground"
            android:textColor="@color/text_secondary"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_ipv6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_ipv6"
            android:textColor="@color/text_secondary"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_scheduled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_scheduled"
            android:textColor="@color/text_secondary"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_schedule_hours"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

        <EditText
            android:id="@+id/et_schedule_hours"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:inputType="number"/>

        <Button
            android:id="@+id/btn_clear_failed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_clear_failed"
            android:backgroundTint="@color/surface"/>

    </LinearLayout>
</ScrollView>
