<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SenPai Scanner"
                    android:textColor="@color/accent"
                    android:textSize="22sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v2.0 android"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                <Button
                    android:id="@+id/btn_help"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="?"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/surface"
                    android:padding="0dp"/>
            </LinearLayout>

            <!-- Config URL -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONFIG URL  (VLESS / Trojan)"
                android:textColor="@color/text_dim"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_config_url"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="vless://... or trojan://..."
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_dim"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/input_bg"
                    android:padding="12dp"
                    android:inputType="textNoSuggestions"
                    android:maxLines="2"/>

                <ImageButton
                    android:id="@+id/btn_clear"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:layout_gravity="center_vertical"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="@drawable/chip_bg"
                    android:tint="@color/text_dim"
                    android:contentDescription="Clear"/>
            </LinearLayout>

            <!-- Row: Count + Port -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="IPs TO SCAN"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="4dp"/>

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="500"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:background="@drawable/input_bg"
                        android:padding="12dp"
                        android:inputType="number"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PORT"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="4dp"/>

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_port"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="443"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:background="@drawable/input_bg"
                        android:padding="12dp"
                        android:inputType="number"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Concurrency slider -->
            <TextView
                android:id="@+id/tv_concurrency_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="WORKERS  —  50"
                android:textColor="@color/text_dim"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_concurrency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="10"
                android:valueTo="200"
                android:stepSize="10"
                android:value="50"
                app:thumbColor="@color/accent"
                app:trackColorActive="@color/accent"
                app:trackColorInactive="@color/surface"
                android:layout_marginBottom="16dp"/>

            <!-- Timeout slider -->
            <TextView
                android:id="@+id/tv_timeout_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TIMEOUT  —  5s"
                android:textColor="@color/text_dim"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_timeout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="1"
                android:valueTo="30"
                android:stepSize="1"
                android:value="5"
                app:thumbColor="@color/accent"
                app:trackColorActive="@color/accent"
                app:trackColorInactive="@color/surface"
                android:layout_marginBottom="16dp"/>

            <!-- Custom CIDR -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CUSTOM CIDR  (optional)"
                android:textColor="@color/text_dim"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_cidr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 104.16.0.0/13"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_dim"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:background="@drawable/input_bg"
                android:padding="12dp"
                android:inputType="textNoSuggestions"
                android:layout_marginBottom="16dp"/>

            <!-- Mode chips -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PROBE MODE"
                android:textColor="@color/text_dim"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/chip_tcp"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="TCP"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/chip_bg"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/chip_tls"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="TLS"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/chip_bg"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/chip_http"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="HTTP"
                    android:gravity="center"
                    android:textColor="@color/accent"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/chip_selected_bg"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Healthy Only toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="HEALTHY ONLY  /  فقط سالم‌ها"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_healthy_only"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    app:thumbTint="@color/accent"
                    app:trackTint="@color/surface_variant"/>
            </LinearLayout>


            <!-- Scan button -->
            <Button
                android:id="@+id/btn_scan"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="▶  SCAN"
                android:textColor="@color/bg_primary"
                android:textSize="15sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:backgroundTint="@color/accent"
                android:layout_marginBottom="8dp"/>

            <!-- Progress -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_scan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="invisible"
                app:indicatorColor="@color/accent"
                app:trackColor="@color/surface"
                android:layout_marginBottom="16dp"/>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:background="@drawable/stats_bg"
                android:padding="12dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_stats_tested" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textColor="@color/text_primary" android:textSize="18sp"
                        android:fontFamily="monospace" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TESTED" android:textColor="@color/text_dim" android:textSize="9sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_stats_healthy" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textColor="@color/good" android:textSize="18sp"
                        android:fontFamily="monospace" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="HEALTHY" android:textColor="@color/text_dim" android:textSize="9sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_stats_failed" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textColor="@color/bad" android:textSize="18sp"
                        android:fontFamily="monospace" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="FAILED" android:textColor="@color/text_dim" android:textSize="9sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_stats_in_flight" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textColor="@color/accent" android:textSize="18sp"
                        android:fontFamily="monospace" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ACTIVE" android:textColor="@color/text_dim" android:textSize="9sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Results header + action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RESULTS"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:fontFamily="monospace"/>

                <Button
                    android:id="@+id/btn_export"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="CSV"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/surface"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone"/>

                <Button
                    android:id="@+id/btn_share"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="↑"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/surface"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone"/>

                <Button
                    android:id="@+id/btn_copy"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="⎘"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/accent"
                    android:backgroundTint="@color/surface"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Column headers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp"
                android:paddingHorizontal="8dp">

                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="3" android:text="IP:PORT"
                    android:textColor="@color/text_dim" android:textSize="10sp" android:fontFamily="monospace"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="2" android:text="LATENCY"
                    android:textColor="@color/text_dim" android:textSize="10sp" android:fontFamily="monospace"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="LOSS"
                    android:textColor="@color/text_dim" android:textSize="10sp" android:fontFamily="monospace"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="QUAL"
                    android:textColor="@color/text_dim" android:textSize="10sp" android:fontFamily="monospace"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="COLO"
                    android:textColor="@color/text_dim" android:textSize="10sp" android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- Empty state -->
            <TextView
                android:id="@+id/tv_empty"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="Press SCAN to start"
                android:gravity="center"
                android:textColor="@color/text_dim"
                android:textSize="13sp"
                android:fontFamily="monospace"/>

            <!-- Results list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="invisible"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
